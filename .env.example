# 彩云天气 API Token
# 注册地址：https://dashboard.caiyunapp.com/
# 将此文件复制为 .env 并填入你的 token
VITE_CAIYUN_TOKEN=your-caiyun-token
VITE_RAIN_ALERT_SERVER_ORIGIN=http://127.0.0.1:8787

CAIYUN_TOKEN=your-caiyun-token
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:you@example.com
RAIN_ALERT_DB_PATH=./data/rain-alert.sqlite
RAIN_ALERT_PORT=8787

# 调试用：强制跳过雨天判断，直接对所有订阅发推送（仅用于本地测试）
# FORCE_RAIN_ALERT=1

# 代理设置：Node.js 不自动读取系统代理，如需通过代理发 Web Push，在此指定
# HTTPS_PROXY=http://127.0.0.1:7890

